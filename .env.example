# ---- Crypto Trends x402 config ----
# Copy to .env.local and fill in PAY_TO_ADDRESS + CDP keys.

# Wallet that receives USDC paywall payments (REQUIRED)
PAY_TO_ADDRESS=0xYourReceivingWalletAddress

# Price per premium /api/signal call. Escape `$` in dotenv files.
SIGNAL_PRICE=\$0.01

# ---- Network selection ----
# Base mainnet (default, real USDC) — uses the Coinbase CDP facilitator.
# CDP keys are required for mainnet settlement. Create them at
# https://portal.cdp.coinbase.com (free tier: 1,000 settlements/month).
X402_NETWORK=eip155:8453
FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
CDP_API_KEY_ID=...
CDP_API_KEY_SECRET=...

# Base Sepolia (signup-free testnet) — uncomment to switch back:
# X402_NETWORK=eip155:84532
# FACILITATOR_URL=https://x402.org/facilitator
