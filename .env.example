# ---- Crypto Trends x402 config ----
# Copy to .env.local and fill in PAY_TO_ADDRESS.

# Wallet that receives USDC paywall payments (REQUIRED)
PAY_TO_ADDRESS=0xYourReceivingWalletAddress

# Price per premium /api/signal call. Escape `$` in dotenv files.
SIGNAL_PRICE=\$0.05

# ---- Network selection ----
# Base Sepolia (default, free, no signup):
X402_NETWORK=eip155:84532
FACILITATOR_URL=https://x402.org/facilitator

# Base mainnet (real USDC) — uncomment and use the CDP facilitator:
# X402_NETWORK=eip155:8453
# FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# CDP_API_KEY_ID=...
# CDP_API_KEY_SECRET=...
